{
  "name": "parking-spots",
  "version": "1.0.0",
  "description": "Cloudflare Worker for scraping free parking spots",
  "main": "src/index.ts",
  "scripts": {
    "dev": "pnpm run build && wrangler dev",
    "build:frontend": "cd src/frontend && pnpm build",
    "build": "pnpm build:frontend",
    "deploy": "pnpm build && wrangler deploy",
    "adhocquery:local": "wrangler d1 execute --local parking_spots_db --command \"$(cat src/api/adhocQuery.sql)\"",
    "adhocquery:remote": "wrangler d1 execute --remote parking_spots_db --command \"$(cat src/api/adhocQuery.sql)\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.82.2"
  },
  "dependencies": {
    "itty-router": "^5.0.23"
  }
}
