{
  "name": "parking-spots",
  "version": "1.0.0",
  "description": "Cloudflare Worker for scraping free parking spots",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "adhocquery:local": "wrangler d1 execute --local parking_spots_db --command \"$(cat src/adhoc-query.sql)\"",
    "adhocquery:remote": "wrangler d1 execute --remote parking_spots_db --command \"$(cat src/adhoc-query.sql)\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.82.2"
  }
}
